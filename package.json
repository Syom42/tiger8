{
  "name": "tiger8",
  "version": "2.0.0",
  "description": "Tiger8 — Hebrew fitness tracking web app (Vercel + Postgres + Hono + Drizzle)",
  "main": "index.js",
  "packageManager": "npm@10.9.2",
  "scripts": {
    "dev": "npm run dev:api",
    "dev:api": "vercel dev --yes --listen 3000",
    "dev:web": "vite --host 127.0.0.1 --port 5173 --strictPort",
    "dev:web:vercel": "vite --host 127.0.0.1",
    "build": "vite build",
    "type-check": "tsc --noEmit",
    "qa:smoke": "node scripts/qa-smoke.mjs",
    "vercel-build": "npm run build",
    "db:generate": "drizzle-kit generate",
    "db:push": "drizzle-kit push",
    "db:seed": "node scripts/db-seed.mjs",
    "db:bootstrap": "npm run db:push && npm run db:seed"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/supersushuka-spec/tiger8.git"
  },
  "keywords": [],
  "author": "",
  "license": "ISC",
  "type": "module",
  "bugs": {
    "url": "https://github.com/supersushuka-spec/tiger8/issues"
  },
  "homepage": "https://github.com/supersushuka-spec/tiger8#readme",
  "dependencies": {
    "@capacitor/android": "^8.3.4",
    "@capacitor/cli": "^8.3.4",
    "@capacitor/core": "^8.3.4",
    "@hono/zod-validator": "^0.4.2",
    "@vercel/postgres": "^0.10.0",
    "bcryptjs": "^2.4.3",
    "drizzle-orm": "^0.45.2",
    "hono": "^4.6.14",
    "jose": "^5.10.0",
    "lucide-react": "^0.487.0",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "recharts": "^2.15.2",
    "zod": "^3.23.8"
  },
  "devDependencies": {
    "@tailwindcss/vite": "^4.1.12",
    "@types/node": "^22.10.0",
    "@types/react": "^18.3.12",
    "@types/react-dom": "^18.3.1",
    "@vitejs/plugin-react": "^4.7.0",
    "concurrently": "^9.1.0",
    "dotenv": "^16.6.1",
    "drizzle-kit": "^0.30.1",
    "tailwindcss": "^4.1.12",
    "tw-animate-css": "^1.3.8",
    "typescript": "^5.7.2",
    "vercel": "^56.4.1",
    "vite": "^6.3.5"
  }
}
